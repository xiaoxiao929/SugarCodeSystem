<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>會員登入 - SUGAR CODE</title>
    <style>
        body { background: #FAFAFA; font-family: STHeiti, sans-serif; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .box { background: #FFFFFF; width: 450px; padding: 40px; box-shadow: 0 15px 50px rgba(0,0,0,0.05); border: 1px solid #EAEAEA; text-align: left; }
        .title { font-size: 1.4rem; letter-spacing: 2px; font-weight: bold; border-bottom: 2px solid #C5A880; padding-bottom: 10px; margin-bottom: 30px; }
        .form-group { margin-bottom: 20px; }
        label { font-size: 0.85rem; color: #666; display: block; margin-bottom: 6px; }
        input { width: 100%; padding: 12px; border: 1px solid #E0E0E0; background: #FAFAFA; box-sizing: border-box; }
        input:focus { border-color: #C5A880; outline: none; background: #FFF; }
        .btn { width: 100%; background: #111; color: white; border: none; padding: 14px; cursor: pointer; letter-spacing: 2px; font-weight: bold; }
        .btn:hover { background: #C5A880; }
        .msg { padding: 12px; margin-bottom: 20px; font-size: 0.9rem; text-align: center; border-left: 4px solid #EC4899; background: #FDF2F2; color: #EC4899; }
    </style>
</head>
<body>
    <div class="box">
        <div class="title">會員安全登入系統</div>
        
        <% if (error) { %> <div class="msg"><%= error %></div> <% } %>
        <% if (success) { %> <div class="msg" style="background:#F0FDF4; color:#15803D; border-color:#15803D;"><%= success %></div> <% } %>

        <form action="/login/auth" method="POST">
            <div class="form-group">
                <label>工作帳號</label>
                <input type="text" name="username" required placeholder="請輸入您的註冊帳號">
            </div>
            <div class="form-group">
                <label>安全密碼</label>
                <input type="password" name="password" required placeholder="請輸入密碼">
            </div>
            <button type="submit" class="btn">驗證並安全登入</button>
        </form>

        <div style="margin-top: 25px; text-align: center; font-size: 0.9rem;">
            <span style="color:#666;">還不是尊榮會員嗎？</span>
            <a href="/register" style="color:#C5A880; font-weight:bold; text-decoration:none;">點擊在此快速註冊 ➔</a>
            <a href="/forgot">忘記密碼？</a>
        </div>
        
        <div style="text-align:center; margin-top:15px;"><a href="/" style="font-size:0.8rem; color:#999; text-decoration:none;">⬅ 返回首頁</a></div>
    </div>
</body>
</html>