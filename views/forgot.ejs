<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>安全重設密碼 - SUGAR CODE</title>
    <style>
        body { background: #FAFAFA; font-family: STHeiti, sans-serif; margin: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .box { background: #FFFFFF; width: 420px; padding: 40px; border: 1px solid #EAEAEA; box-shadow: 0 15px 50px rgba(0,0,0,0.05); }
        .form-group { margin-bottom: 18px; text-align: left; }
        label { font-size: 0.85rem; color: #666; display: block; margin-bottom: 6px; }
        input { width: 100%; padding: 12px; border: 1px solid #E0E0E0; background: #FAFAFA; box-sizing: border-box; }
        .btn { width: 100%; background: #111; color: white; border: none; padding: 14px; cursor: pointer; font-weight: bold; }
        .btn:hover { background: #C5A880; }
    </style>
</head>
<body>
    <div class="box">
        <h3 style="margin-top:0; border-bottom:2px solid #C5A880; padding-bottom:10px; text-align:left;">🔒 會員安全重設密碼中心</h3>
        <% if (message) { %> <div style="color:red; font-size:0.9rem; margin-bottom:15px; text-align:left;"><%= message %></div> <% } %>
        
        <form action="/forgot/reset" method="POST">
            <div class="form-group"><label>請輸入您的原工作帳號</label><input type="text" name="username" required></div>
            <div class="form-group"><label>請輸入您註冊的手機號碼進行安全校驗</label><input type="text" name="phone" required></div>
            <div class="form-group"><label>設定全新安全密碼</label><input type="password" name="newPassword" required placeholder="請填寫欲變更的新密碼"></div>
            <button type="submit" class="btn">驗證並即時變更密碼</button>
        </form>
        <div style="text-align:center; margin-top:20px;"><a href="/login" style="font-size:0.85rem; color:#999; text-decoration:none;">⬅ 返回登入頁面</a></div>
    </div>
</body>
</html>