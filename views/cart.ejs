<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>我的購物車 - SUGAR CODE</title>
    <style>
        body { background: #FFFFFF; font-family: STHeiti, sans-serif; margin: 0; padding-top: 100px; }
        .navbar { position: fixed; top: 0; left: 0; width: 100%; background: white; border-bottom: 1px solid #EAEAEA; display: flex; justify-content: space-between; align-items: center; padding: 15px 60px; box-sizing: border-box; }
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 14px; border-bottom: 1px solid #EAEAEA; text-align: left; }
        th { background: #FAFAFA; color:#C5A880; }
        .btn { background: #111; color: white; border: none; padding: 12px 30px; cursor: pointer; text-decoration: none; display: inline-block; }
        .btn:hover { background: #C5A880; }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" style="font-size:1.4rem; font-weight:bold; color:#111; text-decoration:none;">SUGAR <span style="color:#C5A880;">CODE</span></a>
        <div><a href="/shop" style="color:#111; text-decoration:none; font-size:0.9rem; font-weight:bold;">⬅ 返回商品列表</a></div>
    </nav>

    <div class="container">
        <h3 style="border-left: 4px solid #C5A880; padding-left:15px; font-weight:300;">🛒 您目前的專屬購物車暫存車</h3>
        <% if (cart.length === 0) { %>
            <p style="color:#888; padding:40px 0; text-align:center;">目前購物車內沒有任何甜點品項。</p>
        <% } else { %>
            <table>
                <thead>
                    <tr><th>商品名稱</th><th>配置類型</th><th>智慧糖分</th><th>配件</th><th>雕刻字樣</th><th>小計</th></tr>
                </thead>
                <tbody>
                    <% cart.forEach(item => { %>
                        <tr>
                            <td><strong><%= item.name %></strong></td>
                            <td><%= item.type %></td>
                            <td><%= item.sugar %></td>
                            <td><%= item.candle %></td>
                            <td><%= item.text %></td>
                            <td style="color:#C5A880;">$<%= item.price %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            <div style="text-align: right; margin-top: 20px;">
                <span style="font-size: 1.3rem; margin-right: 30px;">應付總金額：<strong>$<%= total %> NTD</strong></span>
                <a href="/cart/clear" class="btn" style="background:#999;">清空暫存車</a>
                <form action="/cart/checkout" method="POST" style="display:inline;">
                    <button type="submit" class="btn">結帳 ➔</button>
                </form>
            </div>
        <% } %>
    </div>
</body>
</html>